# ─────────────────────────────────────────────────────────────
# Variables d'environnement — Chanson Pour Toujours (Netlify Functions)
# NE PAS committer de vraies valeurs. Configurer dans Netlify :
# Site settings > Environment variables. Ce fichier = documentation.
# ─────────────────────────────────────────────────────────────

# ── Airtable (base CPT « Chanson Pour Toujours ») ──
AIRTABLE_BASE_ID=appuLadYUzLEmHZff
AIRTABLE_TOKEN=

# ── Stripe (sous-compte CPT) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SONG=                 # produit principal, 79,97 $
STRIPE_PRICE_INSTRUMENTAL=         # add-on instrumentale, 15,99 $
STRIPE_PRICE_PAROLES_VIVANTES=     # add-on paroles karaoké, 13,99 $

# ── Webhooks Make (dossier CPT 322127) ──
MAKE_C_GEN_WEBHOOK_URL=            # scénario CPT - MAKE C-gen
MAKE_CCB_WEBHOOK_URL=             # scénario CPT - MAKE C-cb (callback Suno)
MAKE_CADEAUX_WEBHOOK_URL=          # scénario cadeaux (PDF/signet)
MAKE_WEBHOOK_SECRET=

# ── Mailgun (sous-domaines de réponse CPT ; affichage = domaine principal) ──
MAILGUN_API_KEY=
MAILGUN_SIGNING_KEY=
MAILGUN_DOMAIN_ACHAT=achat.chansonpourtoujours.ca
MAILGUN_DOMAIN_SUPPORT=support.chansonpourtoujours.ca
MAILGUN_DOMAIN_MARKETING=info.chansonpourtoujours.ca
MAILGUN_DOMAIN=                    # fallback générique
MAILGUN_FROM=brigitte@chansonpourtoujours.ca
MAILGUN_FROM_SUPPORT=brigitte@chansonpourtoujours.ca
MAILGUN_FROM_MARKETING=brigitte@chansonpourtoujours.ca

# ── IA / médias (mêmes comptes réutilisables) ──
ANTHROPIC_API_KEY=
SUNO_API_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CREATOMATE_API_KEY=
CREATOMATE_API_VERSION=

# ── Meta CAPI (compte CPT — différent, Maxime fournit) ──
META_CAPI_TOKEN=
META_DATASET_ID=

# ── Secrets internes (callbacks / sécurité) ──
CALLBACK_SECRET=
GENERATE_LYRICS_SECRET=

# ── Divers ──
SITE_URL=https://chansonpourtoujours.ca
TEAM_NOTIFY_EMAIL=
CM_POSTAL_ADDRESS=                 # adresse postale CPT (pied de courriel CASL)
SENTINELLE_MAX_RETRIES=3
